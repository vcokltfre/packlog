# Set the bind address for Packlog
BIND_ADDRESS=:8080

# Set the bootstrap admin credentials for Packlog
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# Set the database connection string for Packlog
DATABASE_URL=postgres://user:password@localhost:5432/packlog?sslmode=disable

# Set the external URL for Packlog (used for CORS)
EXTERNAL_URL=http://localhost:8080
